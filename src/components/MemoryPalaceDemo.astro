---
// Interactive Memory Palace demo: force-directed graph with pre-baked nodes
// Ports visual core from hebbs-vault panel graph.js (same physics, same rendering)
---

<section id="memory-palace" class="py-20 md:py-32 border-t border-border/50">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-10">
      <p class="text-xs font-mono text-accent uppercase tracking-wider mb-4">Memory Palace</p>
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        See how your memories connect.
      </h2>
      <p class="text-muted text-lg max-w-3xl mx-auto">
        Episodes cluster by topic. Insights emerge from patterns. Contradictions surface automatically. This is a live simulation of a real HEBBS memory graph.
      </p>
    </div>

    <div class="relative rounded-xl border border-border bg-surface/40 overflow-hidden">
      <canvas id="palace-canvas" class="w-full block" style="height: 600px; cursor: grab;"></canvas>

      <!-- Legend -->
      <div id="palace-legend" class="absolute top-4 right-4 bg-bg/80 backdrop-blur-sm border border-border/60 rounded-lg px-4 py-3 text-xs pointer-events-none">
        <div class="flex items-center gap-2 mb-1.5">
          <span class="inline-block w-3 h-3 rounded-full" style="background: rgba(200, 130, 20, 0.8);"></span>
          <span class="text-muted">Episode</span>
        </div>
        <div class="flex items-center gap-2 mb-1.5">
          <svg class="w-3 h-3" viewBox="0 0 12 12"><polygon points="6,1 10.5,3.5 10.5,8.5 6,11 1.5,8.5 1.5,3.5" fill="rgba(16, 185, 129, 0.8)" /></svg>
          <span class="text-muted">Insight</span>
        </div>
        <div class="border-t border-border/40 my-1.5 pt-1.5">
          <div class="flex items-center gap-2 mb-1">
            <span class="inline-block w-4 border-t-2" style="border-color: rgba(120, 53, 15, 0.7);"></span>
            <span class="text-muted">Causal</span>
          </div>
          <div class="flex items-center gap-2 mb-1">
            <span class="inline-block w-4 border-t-2 border-dashed" style="border-color: rgba(107, 114, 128, 0.5);"></span>
            <span class="text-muted">Similarity</span>
          </div>
          <div class="flex items-center gap-2">
            <span class="inline-block w-4 border-t-2 border-dashed" style="border-color: rgba(239, 68, 68, 0.7);"></span>
            <span class="text-muted">Contradiction</span>
          </div>
        </div>
      </div>

      <!-- Interaction hint -->
      <div id="palace-hint" class="absolute bottom-4 left-1/2 -translate-x-1/2 bg-bg/70 backdrop-blur-sm border border-border/40 rounded-full px-4 py-2 text-xs text-muted pointer-events-none transition-opacity duration-700">
        Hover to inspect &middot; Scroll to zoom &middot; Drag to pan
      </div>

      <!-- Tooltip -->
      <div id="palace-tooltip" class="absolute hidden bg-bg/90 backdrop-blur-sm border border-border/60 rounded-lg px-3 py-2 text-xs pointer-events-none z-10 max-w-xs"></div>
    </div>

    <!-- Stats bar -->
    <div class="mt-4 flex flex-wrap justify-center gap-6 text-sm text-muted font-mono">
      <span><span class="text-accent font-semibold">42</span> memories</span>
      <span><span class="text-green font-semibold">8</span> insights</span>
      <span><span class="text-accent font-semibold">3</span> clusters</span>
      <span><span class="text-red font-semibold">2</span> contradictions</span>
    </div>
  </div>
</section>

