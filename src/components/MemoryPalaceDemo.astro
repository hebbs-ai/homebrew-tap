  // ~55 edges: causal (solid amber), similarity (dashed gray), contradicts (dashed red)
  const DEMO_EDGES = [
    // Causal chains within sales
    { source: 's1',  target: 's3',  type: 'causal', weight: 0.8 },
    { source: 's3',  target: 's8',  type: 'causal', weight: 0.7 },
    { source: 's8',  target: 's11', type: 'causal', weight: 0.6 },
    { source: 's4',  target: 's12', type: 'causal', weight: 0.9 },
    { source: 's5',  target: 's14', type: 'causal', weight: 0.5 },
    { source: 's7',  target: 's10', type: 'causal', weight: 0.7 },
    { source: 's10', target: 's14', type: 'causal', weight: 0.4 },
    { source: 's1',  target: 's2',  type: 'causal', weight: 0.6 },
    { source: 's12', target: 's15', type: 'causal', weight: 0.7 },
