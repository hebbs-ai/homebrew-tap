    { id: 'i8', label: 'Integration complexity underestimated', kind: 'insight', cluster: 2, importance: 0.6, recency: 0.5, reinforcement: 0.5 },
    { id: 'd1', label: 'Acme Q3 pipeline review', kind: 'episode', cluster: 2, importance: 0.6, recency: 0.8, reinforcement: 0.6 },
