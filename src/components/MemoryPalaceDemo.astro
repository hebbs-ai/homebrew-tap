    { id: 'd4', label: 'Forecast accuracy report', kind: 'episode', cluster: 2, importance: 0.6, recency: 0.7, reinforcement: 0.4 },
    { id: 'd5', label: 'Churn risk signals identified', kind: 'episode', cluster: 2, importance: 0.7, recency: 0.4, reinforcement: 0.6 },
