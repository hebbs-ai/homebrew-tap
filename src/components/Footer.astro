---
const year = new Date().getFullYear();
---

<footer class="band-dark border-t border-border/50 py-8">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-6">
        <a href="/" class="flex items-center gap-2 font-logo text-sm font-bold tracking-[0.08em] text-muted hover:text-text transition-colors">
          <img src="/logo-icon.svg" alt="" class="w-4 h-4 rounded-sm opacity-50 group-hover:opacity-100 transition-opacity" />
          HEBBS
        </a>
        <a href="https://github.com/hebbs-ai/hebbs" target="_blank" rel="noopener" class="text-xs text-muted hover:text-text transition-colors">GitHub</a>
        <a href="mailto:support@hebbs.ai" class="text-xs text-muted hover:text-text transition-colors">Contact</a>
      </div>

      <div class="flex items-center gap-6">
        <a href="https://hebbs.ai" class="text-xs text-muted/50 hover:text-muted transition-colors">hebbs.ai</a>
        <span class="text-xs text-muted/30">&middot;</span>
        <span class="text-xs text-muted/50">&copy; {year} hebbs.ai</span>
      </div>
    </div>

    <p class="text-[10px] text-muted/30 text-center mt-6">
      All product names, logos, and trademarks referenced are property of their respective owners. HEBBS is not affiliated with or endorsed by any of these projects.
    </p>
  </div>
</footer>
