---
const year = new Date().getFullYear();
---

<footer class="border-t border-border/50 py-8">
  <div class="mx-auto max-w-6xl px-6">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-6">
        <a href="/" class="font-logo text-sm font-bold tracking-[0.08em] text-muted hover:text-text transition-colors">HEBBS</a>
        <a href="https://github.com/hebbs-ai/hebbs" target="_blank" rel="noopener" class="text-xs text-muted hover:text-text transition-colors">GitHub</a>
        <a href="mailto:support@hebbs.ai" class="text-xs text-muted hover:text-text transition-colors">Contact</a>
      </div>

      <div class="flex items-center gap-6">
        <span class="text-xs text-muted/50">&copy; {year} Parag Arora</span>
      </div>
    </div>

    <p class="text-[10px] text-muted/30 text-center mt-6">
      Redis is a registered trademark of Redis Ltd. Apache Kafka is a registered trademark of the Apache Software Foundation. All trademarks are property of their respective owners. HEBBS is not affiliated with or endorsed by any of these projects.
    </p>
  </div>
</footer>
