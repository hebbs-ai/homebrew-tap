---
---

<section id="contact" class="py-24 md:py-40 border-t border-border/50">
  <div class="relative mx-auto max-w-3xl px-6 text-center">
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] rounded-full bg-accent/[0.03] blur-[100px]"></div>
    </div>

    <div class="relative">
      <h2 class="font-logo text-4xl md:text-5xl font-bold tracking-[0.06em] mb-6">
        HEBBS
      </h2>
      <p class="text-xl text-text/90 font-medium mb-3">
        The memory primitive for AI agents.
      </p>
      <p class="text-muted mb-12">
        Built in the open.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
        <a
          href="https://buxo.ai/parag/hebbsai-quick-chat-with-founder"
          target="_blank"
          rel="noopener"
          class="rounded-lg bg-accent px-8 py-3.5 text-sm font-medium text-bg hover:bg-accent/90 transition-colors"
        >
          Talk to us
        </a>
        <a
          href="https://github.com/hebbs-ai/hebbs"
          target="_blank"
          rel="noopener"
          class="rounded-lg border border-border px-8 py-3.5 text-sm font-medium text-muted hover:text-text hover:border-muted transition-colors"
        >
          Star on GitHub
        </a>
      </div>

      <div class="font-mono text-sm text-muted">
        <span class="text-accent">384ns</span> writes &middot;
        <span class="text-accent">114ns</span> reads &middot;
        <span class="text-accent">8ms</span> recall at <span class="text-accent">10M</span> &middot;
        one binary
      </div>
    </div>
  </div>
</section>
