---
const capabilities = [
  { name: "Recall strategies", hebbs: "4", pgvector: "1", qdrant: "1", neo4j: "1-2", wrappers: "1-2" },
  { name: "Temporal recall", hebbs: true, pgvector: false, qdrant: false, neo4j: false, wrappers: false },
  { name: "Causal reasoning", hebbs: true, pgvector: false, qdrant: false, neo4j: "Partial", wrappers: false },
  { name: "Analogical transfer", hebbs: true, pgvector: false, qdrant: false, neo4j: false, wrappers: false },
  { name: "Native decay & reinforcement", hebbs: true, pgvector: false, qdrant: false, neo4j: false, wrappers: false },
  { name: "Background consolidation", hebbs: true, pgvector: false, qdrant: false, neo4j: false, wrappers: "Partial" },
  { name: "Revision with lineage", hebbs: true, pgvector: false, qdrant: false, neo4j: false, wrappers: false },
  { name: "Drop-in agent skill", hebbs: true, pgvector: false, qdrant: false, neo4j: false, wrappers: false },
  { name: "LLM calls on hot path", hebbs: "Zero", pgvector: "N/A", qdrant: "N/A", neo4j: "N/A", wrappers: "Yes" },
  { name: "Recall latency (10M)", hebbs: "<10ms", pgvector: "~20ms", qdrant: "~10ms", neo4j: "~50ms", wrappers: "50-200ms" },
  { name: "Runtime dependencies", hebbs: "None", pgvector: "Postgres", qdrant: "Qdrant", neo4j: "JVM + Neo4j", wrappers: "3-4 services" },
];

const products = [
  { key: "hebbs", label: "HEBBS" },
  { key: "pgvector", label: "pgvector" },
  { key: "qdrant", label: "Qdrant" },
  { key: "neo4j", label: "Neo4j" },
  { key: "wrappers", label: "Memory Wrappers" },
];
---

<section class="py-20 md:py-32 border-t border-border/50">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Why not just use...
      </h2>
      <p class="text-muted text-lg">
        Different category. Different architecture. Different capabilities.
      </p>
    </div>

    <div class="rounded-xl border border-border bg-surface/40 overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border">
            <th class="text-left text-muted font-normal py-4 px-6 min-w-[200px]">Capability</th>
            {products.map((p) => (
              <th class={`text-center font-mono text-xs py-4 px-4 min-w-[100px] ${p.key === 'hebbs' ? 'text-accent font-medium' : 'text-muted font-normal'}`}>
                {p.label}
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {capabilities.map((cap) => (
            <tr class="border-b border-border/50">
              <td class="py-3 px-6 text-text text-sm">{cap.name}</td>
              {products.map((p) => {
                const val = cap[p.key as keyof typeof cap];
                return (
                  <td class="py-3 px-4 text-center text-xs font-mono">
                    {val === true ? (
                      <span class={p.key === 'hebbs' ? 'text-accent' : 'text-green'}>&#10003;</span>
                    ) : val === false ? (
                      <span class="text-muted/40">&mdash;</span>
                    ) : (
                      <span class={p.key === 'hebbs' ? 'text-accent font-medium' : 'text-muted'}>{val}</span>
                    )}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>
</section>
