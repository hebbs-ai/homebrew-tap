---
---

<section class="py-20 md:py-32 border-t border-border/50">
  <div class="mx-auto max-w-5xl px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Your agent doesn't just store. It learns.
      </h2>
      <p class="text-muted text-lg max-w-3xl mx-auto">
        The <span class="text-text font-medium">reflect</span> pipeline clusters raw memories, proposes insights, validates them, and stores consolidated knowledge with full lineage back to source memories.
      </p>
    </div>

    <div class="rounded-xl border border-border bg-surface/40 p-6 md:p-10 overflow-x-auto">
      <div class="space-y-8">
        <!-- Raw episodes -->
        <div>
          <p class="font-mono text-xs text-muted uppercase tracking-wider mb-4">Raw memories (episodes)</p>
          <div class="space-y-2">
            <div class="rounded-lg bg-bg border border-border px-4 py-2.5">
              <p class="text-sm text-muted font-mono">"Customer asked about pricing"</p>
            </div>
            <div class="rounded-lg bg-bg border border-border px-4 py-2.5">
              <p class="text-sm text-muted font-mono">"Customer mentioned competitor X"</p>
            </div>
            <div class="rounded-lg bg-bg border border-border px-4 py-2.5">
              <p class="text-sm text-muted font-mono">"Customer objected to annual commitment"</p>
            </div>
            <div class="rounded-lg bg-bg border border-border px-4 py-2.5">
              <p class="text-sm text-muted font-mono">"Deal lost to competitor X"</p>
            </div>
          </div>
        </div>

        <!-- Arrow -->
        <div class="flex items-center justify-center gap-3">
          <div class="h-px flex-1 bg-accent/30"></div>
          <div class="rounded-lg border border-accent/30 bg-accent/[0.06] px-4 py-2">
            <p class="font-mono text-xs text-accent">reflect (automatic consolidation)</p>
          </div>
          <div class="h-px flex-1 bg-accent/30"></div>
        </div>

        <!-- Insight -->
        <div>
          <p class="font-mono text-xs text-accent uppercase tracking-wider mb-4">Insight (with lineage)</p>
          <div class="rounded-lg border border-accent/30 bg-accent/[0.04] px-5 py-4">
            <p class="text-sm text-text leading-relaxed mb-3">
              "Deals mentioning competitor X with pricing objections have 73% loss rate when annual commitment is pushed early"
            </p>
            <div class="flex flex-wrap gap-2">
              <span class="rounded-md bg-bg border border-border px-2 py-1 text-[10px] font-mono text-muted">confidence: 0.84</span>
              <span class="rounded-md bg-bg border border-border px-2 py-1 text-[10px] font-mono text-muted">sources: 4 memories</span>
              <span class="rounded-md bg-bg border border-border px-2 py-1 text-[10px] font-mono text-accent">sales</span>
              <span class="rounded-md bg-bg border border-border px-2 py-1 text-[10px] font-mono text-accent">pricing</span>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="grid md:grid-cols-3 gap-6 mt-8">
      <div class="text-center py-4">
        <p class="font-mono text-sm font-medium text-accent">Lineage</p>
        <p class="text-xs text-muted mt-1">Every insight traces back to source memories</p>
      </div>
      <div class="text-center py-4">
        <p class="font-mono text-sm font-medium text-accent">Decay</p>
        <p class="text-xs text-muted mt-1">Memories fade unless reinforced by access</p>
      </div>
      <div class="text-center py-4">
        <p class="font-mono text-sm font-medium text-accent">Revision</p>
        <p class="text-xs text-muted mt-1">revise() replaces beliefs, keeps predecessor chain</p>
      </div>
    </div>
  </div>
</section>
