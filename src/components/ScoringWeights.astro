---
const examples = [
  {
    intent: "Show me the closest match.",
    scenario: "RAG retrieval, fact lookup, semantic deduplication",
    weights: { relevance: 1.0, recency: 0.0, importance: 0.0, reinforcement: 0.0 },
  },
  {
    intent: "What just happened?",
    scenario: "Live conversation context, incident response, session replay",
    weights: { relevance: 0.2, recency: 0.6, importance: 0.1, reinforcement: 0.1 },
  },
  {
    intent: "Only the critical stuff.",
    scenario: "Compliance alerts, escalation triage, executive briefings",
    weights: { relevance: 0.3, recency: 0.1, importance: 0.5, reinforcement: 0.1 },
  },
  {
    intent: "What keeps coming up?",
    scenario: "Recurring objections, habit detection, pattern reinforcement",
    weights: { relevance: 0.2, recency: 0.1, importance: 0.2, reinforcement: 0.5 },
  },
];

const signals = [
  { key: "relevance", label: "Relevance", color: "bg-cyan" },
  { key: "recency", label: "Recency", color: "bg-accent" },
  { key: "importance", label: "Importance", color: "bg-green" },
  { key: "reinforcement", label: "Reinforcement", color: "bg-red/80" },
] as const;
---

<section class="py-20 md:py-32 border-t border-border/50">
  <div class="mx-auto max-w-6xl px-6">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight mb-4">
        Same engine. Different intent.
      </h2>
      <p class="text-muted text-lg max-w-2xl mx-auto">
        Every recall blends four signals into one score. Shift the weights and the
        same query returns completely different results. No extra infrastructure.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-6">
      {examples.map((ex) => (
        <div class="rounded-xl border border-border bg-surface/40 p-6 md:p-8 flex flex-col">
          <p class="text-text font-medium text-lg mb-1">"{ex.intent}"</p>
          <p class="text-muted text-sm mb-6">{ex.scenario}</p>

          <div class="flex h-3 rounded-full overflow-hidden mb-5">
            {signals.map((s) => {
              const w = ex.weights[s.key as keyof typeof ex.weights];
              return w > 0 ? (
                <div
                  class={`${s.color} transition-all`}
                  style={`width: ${w * 100}%`}
                />
              ) : null;
            })}
          </div>

          <div class="grid grid-cols-4 gap-2">
            {signals.map((s) => {
              const w = ex.weights[s.key as keyof typeof ex.weights];
              return (
                <div class="text-center">
                  <p class={`font-mono text-lg font-bold ${w > 0 ? 'text-text' : 'text-muted/30'}`}>
                    {w.toFixed(1)}
                  </p>
                  <p class="text-[10px] text-muted uppercase tracking-wider mt-0.5">{s.label}</p>
                </div>
              );
            })}
          </div>
        </div>
      ))}
    </div>

    <div class="mt-8 flex justify-center gap-6 flex-wrap">
      {signals.map((s) => (
        <div class="flex items-center gap-2">
          <div class={`w-3 h-3 rounded-full ${s.color}`} />
          <span class="text-xs text-muted">{s.label}</span>
        </div>
      ))}
    </div>

    <div class="mt-10 rounded-xl border border-border bg-surface/40 p-6">
      <pre class="text-sm font-mono overflow-x-auto"><code><span class="text-muted">// "Only the critical stuff" - one parameter changes everything</span>
<span class="text-text">results</span> <span class="text-cyan">=</span> <span class="text-cyan">await</span> <span class="text-text">client</span>.<span class="text-text">recall</span>(
    <span class="text-green">"contract renewal"</span>,
    <span class="text-text">strategies</span><span class="text-cyan">=</span>[<span class="text-green">"similarity"</span>],
    <span class="text-text">scoring_weights</span><span class="text-cyan">=</span>{"{"}<span class="text-green">"w_relevance"</span>: <span class="text-accent">0.3</span>, <span class="text-green">"w_recency"</span>: <span class="text-accent">0.1</span>, <span class="text-green">"w_importance"</span>: <span class="text-accent">0.5</span>, <span class="text-green">"w_reinforcement"</span>: <span class="text-accent">0.1</span>{"}"},
)</code></pre>
    </div>
  </div>
</section>
