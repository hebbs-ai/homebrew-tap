---
---

<section class="relative pt-40 pb-24 md:pt-52 md:pb-32">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-accent/[0.03] blur-[120px]"></div>
  </div>

  <div class="relative mx-auto max-w-4xl px-6 text-center">
    <h1 class="font-logo text-5xl md:text-7xl font-bold tracking-[0.06em] mb-8">
      HEBBS
    </h1>

    <p class="text-xl md:text-2xl font-medium text-text/90 tracking-tight mb-12">
      The memory primitive for AI agents.
    </p>

    <div class="inline-block rounded-xl border border-border bg-surface/60 px-8 py-5 mb-14">
      <p class="font-mono text-sm md:text-base">
        <span class="text-accent font-medium">384ns</span>
        <span class="text-muted"> writes</span>
        <span class="text-muted mx-3">&middot;</span>
        <span class="text-accent font-medium">114ns</span>
        <span class="text-muted"> reads</span>
        <span class="text-muted mx-3">&middot;</span>
        <span class="text-accent font-medium">8ms</span>
        <span class="text-muted"> recall at </span>
        <span class="text-accent font-medium">10M</span>
      </p>
    </div>

    <div class="flex items-center justify-center gap-4">
      <a
        href="https://buxo.ai/parag/hebbsai-quick-chat-with-founder"
        target="_blank"
        rel="noopener"
        class="rounded-lg bg-accent px-6 py-3 text-sm font-medium text-bg hover:bg-accent/90 transition-colors"
      >
        Talk to us
      </a>
      <a
        href="https://github.com/hebbs-ai/hebbs"
        target="_blank"
        rel="noopener"
        class="rounded-lg border border-border px-6 py-3 text-sm font-medium text-muted hover:text-text hover:border-muted transition-colors"
      >
        GitHub
      </a>
    </div>
  </div>
</section>
