---
---

<section class="relative pt-40 pb-24 md:pt-52 md:pb-32">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-accent/[0.03] blur-[120px]"></div>
  </div>

  <div class="relative mx-auto max-w-4xl px-6 text-center">
    <img src="/logo-icon.svg" alt="HEBBS" class="mx-auto mb-8 w-16 h-16 rounded-2xl shadow-2xl shadow-accent/10" />
    <h1 class="font-logo text-5xl md:text-7xl font-bold tracking-[0.06em] mb-6">
      HEBBS
    </h1>

    <p class="text-xl md:text-2xl font-medium text-text/90 tracking-tight mb-4">
      Memory that wires itself.
    </p>

    <p class="text-base md:text-lg text-muted max-w-2xl mx-auto mb-12">
      Turn your markdowns and conversations into a memory that recalls, reasons, and catches contradictions.
    </p>

    <div class="inline-flex items-center rounded-xl border border-border bg-surface/60 pl-6 pr-2 py-3 mb-4 gap-3 group cursor-pointer" onclick="navigator.clipboard.writeText('curl -sSf https://hebbs.ai/install | sh')">
      <code class="font-mono text-sm md:text-base text-muted">
        <span class="text-accent">$</span> curl -sSf https://hebbs.ai/install | sh
      </code>
      <span class="rounded-lg border border-border bg-bg px-3 py-1.5 text-xs text-muted group-hover:text-text group-hover:border-muted transition-colors">
        Copy
      </span>
    </div>

    <p class="text-xs text-muted/60 mb-10">
      or <code class="font-mono text-xs text-muted/80 cursor-pointer hover:text-muted transition-colors" onclick="navigator.clipboard.writeText('brew install hebbs-ai/tap/hebbs')">brew install hebbs-ai/tap/hebbs</code>
    </p>

    <div class="flex items-center justify-center gap-4 mb-14">
      <a
        href="https://docs.hebbs.ai/guide/"
        target="_blank"
        rel="noopener"
        class="rounded-lg bg-accent px-6 py-3 text-sm font-medium text-white hover:bg-accent/90 transition-colors"
      >
        Get started
      </a>
      <a
        href="https://github.com/hebbs-ai/hebbs"
        target="_blank"
        rel="noopener"
        class="rounded-lg border border-border px-6 py-3 text-sm font-medium text-muted hover:text-text hover:border-muted transition-colors"
      >
        GitHub
      </a>
    </div>

    <div class="font-mono text-sm text-muted">
      <span class="text-accent font-medium">4</span>
      <span class="text-muted"> recall strategies</span>
      <span class="text-muted mx-1.5">&middot;</span>
      <span class="text-accent font-medium">Native</span>
      <span class="text-muted"> consolidation</span>
      <span class="text-muted mx-1.5">&middot;</span>
      <span class="text-accent font-medium">Auto</span>
      <span class="text-muted"> decay</span>
      <span class="text-muted mx-1.5">&middot;</span>
      <span class="text-accent font-medium">1</span>
      <span class="text-muted"> binary</span>
    </div>
  </div>
</section>

<section class="relative py-16 md:py-20">
  <div class="relative mx-auto max-w-3xl px-6 text-center">
    <p class="text-2xl md:text-3xl font-medium text-text/80 tracking-tight leading-snug">
      The design decision
    </p>
    <p class="mt-6 text-lg md:text-xl text-muted max-w-2xl mx-auto leading-relaxed">
      Your agent is already smarter than your memory system.<br/>
      <span class="text-text/90 font-medium">Let it act like it.</span>
    </p>
  </div>
</section>
